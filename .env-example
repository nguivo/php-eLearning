# Application
APP_NAME="eLearning Platform"
APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost

# Database
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=9090
DB_NAME=platform_db
DB_USER=web_user
DB_PASS=password
DB_CHARSET=utf8mb4

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@elearning.com
MAIL_FROM_NAME="eLearning Platform"

# Session
SESSION_LIFETIME=120
SESSION_SECURE=false
